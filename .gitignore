# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# playwright — verification artifacts (videos, traces, screenshots) are for
# reviewing a change, never for committing. Prefer recording to the scratchpad;
# these patterns are the safety net when a run lands in the repo.
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/videos/
*.webm
*.zip.trace
