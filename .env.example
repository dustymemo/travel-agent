# ── AI provider ────────────────────────────────────────────────
# Local CLIs (personal, free): claude-cli | codex-cli   |   Phase 2 (public): claude-api
# Set `fake` for the deterministic offline planner (no real model — demo/dev/tests).
# Unset defaults to claude-cli.
TRAVEL_AI_PROVIDER=claude-cli
# claude-cli model id or CLI alias (sonnet/opus/fable). claude-sonnet-5 -> `sonnet`.
TRAVEL_AI_MODEL=claude-sonnet-5
# codex-cli only (TA-59): model for `codex exec`. Blank = Codex CLI's own default.
TRAVEL_CODEX_MODEL=

# Phase 1 only — long-lived token from `claude setup-token`
# (log in once with your Gmail-linked Claude account, then generate it).
# Used by the CLI inside the Docker container. Leave blank for local dev
# where you're already logged into `claude`.
CLAUDE_CODE_OAUTH_TOKEN=

# Phase 2 only — Claude API key (NOT needed while using claude-cli)
ANTHROPIC_API_KEY=

# ── Supabase (free tier) ───────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only; never exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=
